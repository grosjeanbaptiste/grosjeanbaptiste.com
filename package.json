{
  "name": "grosjeanbaptiste.github.io",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "description": "Personal portfolio/resume — static site generated from resume.json.",
  "scripts": {
    "generate": "node scripts/generate-from-resume.js",
    "pdf": "node scripts/generate-pdf.js",
    "lint": "biome check --error-on-warnings .",
